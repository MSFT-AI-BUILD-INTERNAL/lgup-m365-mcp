# Ignore root-level compiled ARM output (e.g. main.json), keep bicep config and app sources
/*.json
!/bicepconfig.json
!*.bicepparam

# Node
node_modules/
dist/

# Python / uv
**/.venv/
**/.pytest_cache/
**/__pycache__/

# Local/private Bicep parameter files with real environment values
*.local.bicepparam
*.private.bicepparam
*.secrets.bicepparam
**/main.dev.bicepparam

# Local-only files (not to be committed)
docs/drm_call.txt

# macOS
.DS_Store
**/.DS_Store
