{
  "formatting": {
    "indentKind": "Space",
    "indentSize": 2,
    "insertFinalNewline": true,
    "newlineKind": "LF"
  },
  "analyzers": {
    "core": {
      "enabled": true,
      "rules": {
        "adminusername-should-not-be-literal": {
          "level": "warning"
        },
        "no-hardcoded-env-urls": {
          "level": "off"
        },
        "no-unused-params": {
          "level": "warning"
        },
        "no-unused-vars": {
          "level": "warning"
        },
        "secure-parameter-default": {
          "level": "warning"
        }
      }
    }
  }
}