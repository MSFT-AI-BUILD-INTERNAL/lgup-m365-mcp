using './main.bicep'

param namePrefix = 'lgmcp'
param environmentName = 'dev'
param location = 'koreacentral'
param resourceGroupName = 'lgup-rg'

param tags = {
  workload: 'copilot-studio-mcp'
  owner: 'platform-team'
  costCenter: 'tbd'
}

param copilotStudio = {
  tenantId: 'd0a0ff17-cf70-4fc6-b2b9-ad659ff82b30'
  copilotStudioEnvironment: 'dev-kor-6a392e5f'
}

param integrations = {
  apimGatewayUrl: 'https://apim.example.com'
  ngisBaseUrl: 'https://ngis.example.com'
  pssBaseUrl: 'https://pss.example.com'
  tiroBaseUrl: 'https://tiro.example.com'
  confluenceBaseUrl: 'https://confluence.example.com'
  drmApiBaseUrl: 'https://drm.example.com'
}

// The lgmcpdevacreubidyfnm7le4 registry was deleted during the rg-ms-azure-ax-prd
// migration; point at your current ACR (live dev uses lgmcpaxprdacr987d03).
param containerImage = 'lgmcpaxprdacr987d03.azurecr.io/lgup-mcp-server:latest'
param containerPort = 8080
param minReplicas = 1
param maxReplicas = 2
param containerCpu = 1
param containerMemory = '2Gi'

param ngisApiKey = 'replace-me'
param drmApiKey = 'replace-me'

param apimPublisherEmail = 'admin@example.com'
param apimPublisherName = 'LGUP MCP'

param authClientId = 'c33af128-ff89-43c8-9d00-fec530e86e0d'
